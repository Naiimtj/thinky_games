# Copy to `.env` and adjust for your environment.

# Local MySQL (start it with `just db-up`):
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=thinky_games
MYSQL_USER=thinky
MYSQL_PASSWORD=thinky

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=525600
CORS_ORIGINS=["http://localhost:5173"]

# Required (non-empty) to use the /db/backup* admin endpoints.
ADMIN_PASSWORD=

# Required for automatic Crossword words; also enables Wend definitions.
RAE_KEY=