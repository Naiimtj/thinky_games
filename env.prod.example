# =============================================================================
# Variables de entorno para el despliegue en producción (docker-compose.prod.yml)
# Copia este archivo a `.env` (al lado de docker-compose.prod.yml) y rellénalo.
# =============================================================================

# ── Zona horaria ─────────────────────────────────────────────────────────────
TZ=Europe/Madrid

# ── MySQL ────────────────────────────────────────────────────────────────────
MYSQL_DATABASE=thinky_games
MYSQL_USER=thinky
MYSQL_PASSWORD=cambia-esto-en-produccion
MYSQL_ROOT_PASSWORD=cambia-esto-en-produccion

# ── FastAPI ──────────────────────────────────────────────────────────────────
# Genera con: openssl rand -hex 32
JWT_SECRET_KEY=
# Contraseña para los endpoints admin (/db/backup*)
ADMIN_PASSWORD=
# JSON array de orígenes permitidos (debe incluir el dominio final por https)
CORS_ORIGINS=["https://thinkygames.duckdns.org"]
# Obligatoria para palabras automáticas de Crucigrama; habilita definiciones para Wend
RAE_KEY=

# ── PostgreSQL (dictionary service) ──────────────────────────────────────────
DICTIONARY_DB=dictionary
DICTIONARY_USER=dict
DICTIONARY_PASSWORD=cambia-esto-en-produccion

# ── Hosts / certificados (nginx-proxy + acme-companion ya existentes) ───────
VIRTUAL_HOST=thinkygames.duckdns.org
LETSENCRYPT_HOST=thinkygames.duckdns.org
LETSENCRYPT_EMAIL=tu-email@ejemplo.com
